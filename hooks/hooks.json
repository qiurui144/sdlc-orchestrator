{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-write.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-build.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ga-tag-guard.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/secret-guard.sh" }
        ]
      }
    ]
  }
}
